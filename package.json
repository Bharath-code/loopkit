{
  "name": "loopkit",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "cli": "pnpm --filter @loopkit/cli dev",
    "web": "pnpm --filter @loopkit/web dev",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ],
    "packages/shared/src/**/*.{ts,tsx}": [
      "tsc --noEmit -p packages/shared/tsconfig.json"
    ],
    "packages/cli/src/**/*.{ts,tsx}": [
      "tsc --noEmit -p packages/cli/tsconfig.json"
    ],
    "packages/web/src/**/*.{ts,tsx}": [
      "tsc --noEmit -p packages/web/tsconfig.json"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
