{
  "name": "loopkit",
  "version": "0.1.0",
  "description": "The Solo Founder's Shipping OS — Define · Develop · Deliver · Learn · Repeat",
  "type": "module",
  "bin": {
    "loopkit": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/loopkit/loopkit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://loopkit.dev",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch --onSuccess 'echo Build ready'",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.2.0",
    "@clack/prompts": "^0.10.0",
    "@loopkit/shared": "workspace:*",
    "ai": "^4.3.0",
    "chalk": "^5.4.0",
    "commander": "^13.1.0",
    "posthog-node": "^5.30.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "cli",
    "solo-founder",
    "shipping",
    "build-in-public",
    "indie-hacker",
    "productivity"
  ],
  "license": "MIT"
}
